/**
 * Docs sidebar — the "Documentation" home link + the section/link tree. Shared by the
 * landing (index) and each doc (view); the current doc's link gets the active state.
 * Expects: $this->tree (sections), $this->docSlug (active slug, '' on the landing).
 */
$tree   = $this->tree ?: [];
$active = (string) ($this->docSlug ?? '');
$base   = (string) ($this->docsBase ?: '/docs');
?>
<a href="<?= $this->escape($base) ?>" class="d-inline-flex align-items-center text-decoration-none fw-semibold mb-2">
    <i class="fa-solid fa-book me-2"></i><?= $this->translate('docs.title') ?>
</a>
<div class="mb-3">
    <input type="search" class="form-control form-control-sm" data-docs-filter autocomplete="off"
           placeholder="<?= $this->escape($this->translate('docs.filter')) ?>" aria-label="<?= $this->escape($this->translate('docs.filter')) ?>">
</div>
<nav class="nav flex-column" data-docs-nav>
    <?php foreach ($tree as $section): ?>
    <div class="text-uppercase small fw-semibold text-body-secondary mt-3 mb-1" style="letter-spacing:.06em;">
        <?= $this->escape($section['title']) ?>
    </div>
        <?php foreach ($section['items'] as $item): $on = $active === $item['slug']; ?>
    <a class="nav-link py-1 px-2 rounded <?= $on ? 'active bg-primary-subtle text-primary-emphasis fw-semibold' : 'text-body-secondary' ?>"
       href="<?= $this->escape($base) ?>/<?= $this->escape($item['slug']) ?>"><?= $this->escape($item['title']) ?></a>
        <?php endforeach; ?>
    <?php endforeach; ?>
    <div class="nav-link py-1 px-2 small text-body-secondary d-none" data-docs-filter-empty><em>No pages match.</em></div>
</nav>
<script>
(function () {
    var box = document.querySelector('[data-docs-filter]'), nav = document.querySelector('[data-docs-nav]');
    if (!box || !nav || box._wired) { return; }
    box._wired = 1;
    var empty = nav.querySelector('[data-docs-filter-empty]');
    box.addEventListener('input', function () {
        var q = box.value.trim().toLowerCase(), shown = 0;
        nav.querySelectorAll('.nav-link:not([data-docs-filter-empty])').forEach(function (a) {
            var hit = !q || a.textContent.toLowerCase().indexOf(q) !== -1;
            a.style.display = hit ? '' : 'none'; if (hit) { shown++; }
        });
        nav.querySelectorAll(':scope > div:not([data-docs-filter-empty])').forEach(function (h) {
            var any = false, n = h.nextElementSibling;
            while (n && n.tagName !== 'DIV') {
                if (n.classList.contains('nav-link') && n.style.display !== 'none') { any = true; }
                n = n.nextElementSibling;
            }
            h.style.display = (!q || any) ? '' : 'none';
        });
        if (empty) { empty.classList.toggle('d-none', !(q && shown === 0)); }
    });
})();
</script>
