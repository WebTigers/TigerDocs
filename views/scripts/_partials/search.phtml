/**
 * Docs ⌘K search. Rendered from the docs views (so it runs during the action, before the
 * layout), it does three things:
 *   1. Fills the theme's `tigerHeaderSearch` region with the search launcher button — the
 *      placeholder registry is shared view→layout, so the button appears in the header.
 *   2. Emits the (hidden) search modal — a Bootstrap modal opened by ⌘K / "/" / the launcher.
 *   3. Loads the module's published launcher JS + CSS from /_modules/docs (asset symlink).
 * The result links are built client-side from data-docs-base, matching the sidebar's links.
 */
$base    = (string) ($this->docsBase ?: '/docs');
$assets  = '/_modules/docs';
$ph      = (string) $this->escape($this->translate('docs.search.placeholder'));

// Spyglass as an INLINE SVG (FontAwesome's own magnifying-glass path, \f002). Inline so it renders
// regardless of the FA webfont — no cache, no font-blocker, no subset can hide it. `currentColor`
// makes it follow the surrounding text color; sized to the font (1em).
$glass = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em"'
       . ' fill="currentColor" aria-hidden="true" focusable="false" style="vertical-align:-.125em;flex:none;">'
       . '<path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0'
       . 'L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352'
       . 'a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>';

// 1) Header region: the launcher button (centered search slot in the PUMA header).
$this->placeholder('tigerHeaderSearch')->set(
    '<button type="button" data-docs-search-open'
  . ' class="btn btn-sm d-inline-flex align-items-center gap-2 text-body-secondary border rounded-pill px-3 py-1" style="width:30rem;max-width:100%;">'
  . $glass
  . '<span class="me-auto">' . $ph . '</span>'
  . '<kbd class="ms-2">⌘K</kbd>'
  . '</button>'
);

// Docs is a public reading surface — tell the header to drop its sign-up / sign-in CTAs. The
// PUMA header renders the `tigerHeaderAuth` region in place of its default when a feature fills
// it; filling it empty is how a page says "no auth chrome here" (the region contract, no theme edit).
$this->placeholder('tigerHeaderAuth')->set('');
?>
<link rel="stylesheet" href="<?= $this->escape($assets) ?>/docs.search.css">

<!-- 2) The ⌘K search modal (hidden until opened). -->
<div class="modal fade" id="docsSearchModal" tabindex="-1" aria-hidden="true"
     aria-label="<?= $ph ?>" data-docs-base="<?= $this->escape($base) ?>">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <span class="text-body-secondary me-2 d-inline-flex align-items-center"><?= $glass ?></span>
                <input type="search" class="form-control border-0 shadow-none" data-docs-search-input
                       autocomplete="off" placeholder="<?= $ph ?>" aria-label="<?= $ph ?>">
                <kbd class="ms-2">Esc</kbd>
            </div>
            <div class="modal-body py-2">
                <div data-docs-search-results></div>
                <div class="text-body-secondary small text-center py-4" data-docs-search-hint>
                    <?= $this->escape($this->translate('docs.search.hint')) ?>
                </div>
                <div class="text-body-secondary small text-center py-4 d-none" data-docs-search-empty>
                    <?= $this->escape($this->translate('docs.search.empty')) ?>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 3) Launcher JS — defer so it runs after the theme's bootstrap.bundle.js (needed for the modal). -->
<script src="<?= $this->escape($assets) ?>/docs.search.js" defer></script>
