/**
 * A single doc: sticky sidebar + the rendered doc body. The body HTML was produced by
 * Tiger_Cms_Renderer (markdown/html/phtml) in Docs_Model_Docs — output it verbatim.
 * Renders inside the theme's public layout. Expects $this->doc, $this->tree, $this->docSlug.
 */
$doc      = $this->doc;
$headings = $doc['headings'] ?? [];
$mainCol  = $headings ? 'col-lg-7' : 'col-lg-9';   // give the article room only when there's a right rail
$base     = (string) ($this->docsBase ?: '/docs');

// Prev/next pager: flatten the manifest tree to reading order, find this doc, take its neighbours.
$flat = [];
foreach (($this->tree ?: []) as $section) {
    foreach (($section['items'] ?? []) as $item) {
        $flat[] = $item;
    }
}
$idx = null;
foreach ($flat as $i => $f) {
    if (($f['slug'] ?? null) === $this->docSlug) { $idx = $i; break; }
}
$prev = ($idx !== null && $idx > 0)                 ? $flat[$idx - 1] : null;
$next = ($idx !== null && $idx < count($flat) - 1)  ? $flat[$idx + 1] : null;
?>
<?= $this->render('_partials/search.phtml') ?>
<link rel="stylesheet" href="/_modules/docs/vendor/highlight/docs.hljs.css">
<div class="container py-4" style="max-width:1320px;">
    <div class="row g-4">
        <aside class="col-lg-3 col-md-4">
            <div class="sticky-top pt-2" style="top:4.5rem;">
                <?= $this->partial('_partials/nav.phtml', ['tree' => $this->tree, 'docSlug' => $this->docSlug, 'docsBase' => $this->docsBase]) ?>
            </div>
        </aside>

        <main class="<?= $mainCol ?> col-md-8">
            <article class="tiger-docs-body">
                <?= $doc['html'] ?>
            </article>

            <?php if ($prev || $next): ?>
            <nav class="row g-3 border-top mt-5 pt-4" aria-label="<?= $this->escape($this->translate('docs.pager')) ?>">
                <div class="col-6">
                    <?php if ($prev): ?>
                    <a class="docs-pager d-flex flex-column h-100 p-3 border rounded text-decoration-none" href="<?= $this->escape($base) ?>/<?= $this->escape($prev['slug']) ?>">
                        <span class="small text-body-secondary"><i class="fa-solid fa-arrow-left me-2"></i><?= $this->escape($this->translate('docs.prev')) ?></span>
                        <span class="fw-semibold mt-1"><?= $this->escape($prev['title']) ?></span>
                    </a>
                    <?php endif; ?>
                </div>
                <div class="col-6">
                    <?php if ($next): ?>
                    <a class="docs-pager d-flex flex-column h-100 p-3 border rounded text-decoration-none text-end" href="<?= $this->escape($base) ?>/<?= $this->escape($next['slug']) ?>">
                        <span class="small text-body-secondary"><?= $this->escape($this->translate('docs.next')) ?><i class="fa-solid fa-arrow-right ms-2"></i></span>
                        <span class="fw-semibold mt-1"><?= $this->escape($next['title']) ?></span>
                    </a>
                    <?php endif; ?>
                </div>
            </nav>
            <?php endif; ?>
        </main>

        <?php if ($headings): ?>
        <aside class="col-lg-2 d-none d-lg-block">
            <div class="sticky-top pt-2" style="top:4.5rem;">
                <div class="small text-uppercase text-body-secondary mb-2 fw-semibold" style="letter-spacing:.06em;"><?= $this->translate('docs.onthispage') ?></div>
                <nav class="docs-toc nav flex-column border-start ps-3 position-relative" id="docsToc">
                    <span class="docs-toc-marker" aria-hidden="true"></span>
                    <?php foreach ($headings as $h): ?>
                    <a class="nav-link py-1 px-0 small text-body-secondary<?= (int) $h['level'] === 3 ? ' ps-3' : '' ?>" data-toc-link href="#<?= $this->escape($h['id']) ?>"><?= $this->escape($h['text']) ?></a>
                    <?php endforeach; ?>
                </nav>
            </div>
        </aside>
        <script src="/_modules/docs/docs.toc.js" defer></script>
        <?php endif; ?>
    </div>
</div>

<!-- Syntax highlighting: highlight.js core (with php/css/js/xml/ini/bash/json) + php-template for
     PHTML, then our init. All deferred, so they run in order after parse. -->
<script src="/_modules/docs/vendor/highlight/highlight.min.js" defer></script>
<script src="/_modules/docs/vendor/highlight/php-template.min.js" defer></script>
<script src="/_modules/docs/docs.highlight.js" defer></script>
