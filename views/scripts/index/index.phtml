/**
 * Docs landing: sticky sidebar + a welcome and one card per section (linking each doc).
 * Renders inside the theme's public layout — a theme can override this view. Expects
 * $this->tree (sections from the content manifest).
 */
$tree = $this->tree ?: [];
$base = (string) ($this->docsBase ?: '/docs');
?>
<?= $this->render('_partials/search.phtml') ?>
<div class="container py-4" style="max-width:1160px;">
    <div class="row g-4">
        <aside class="col-lg-3 col-md-4">
            <div class="sticky-top pt-2" style="top:4.5rem;">
                <?= $this->partial('_partials/nav.phtml', ['tree' => $tree, 'docSlug' => '', 'docsBase' => $base]) ?>
            </div>
        </aside>

        <main class="col-lg-9 col-md-8">
            <header class="mb-4">
                <div class="small text-uppercase text-body-secondary mb-1" style="letter-spacing:.09em;font-weight:600;"><?= $this->translate('docs.landing.eyebrow') ?></div>
                <h1 class="display-6 fw-bold mb-2"><?= $this->translate('docs.landing.heading') ?></h1>
                <p class="lead text-body-secondary mb-0"><?= $this->translate('docs.landing.lead') ?></p>
            </header>

            <?php if (!$tree): ?>
            <div class="card"><div class="card-body text-body-secondary">
                <i class="fa-regular fa-file-lines me-2"></i>No docs yet — add a file under
                <code>content/en/</code> and list it in <code>content/manifest.json</code>.
            </div></div>
            <?php else: ?>
            <div class="row g-3">
                <?php foreach ($tree as $section): ?>
                <div class="col-sm-6">
                    <div class="card h-100"><div class="card-body">
                        <h2 class="h6 fw-bold mb-3"><?= $this->escape($section['title']) ?></h2>
                        <ul class="list-unstyled mb-0 d-grid gap-2">
                            <?php foreach ($section['items'] as $item): ?>
                            <li>
                                <a class="text-decoration-none" href="<?= $this->escape($base) ?>/<?= $this->escape($item['slug']) ?>">
                                    <i class="fa-regular fa-file-lines me-2 text-body-secondary"></i><?= $this->escape($item['title']) ?>
                                </a>
                            </li>
                            <?php endforeach; ?>
                        </ul>
                    </div></div>
                </div>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
        </main>
    </div>
</div>
